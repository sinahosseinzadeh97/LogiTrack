# =============================================================================
# LogiTrack — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env or any file containing real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=logitrack
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=logitrack
POSTGRES_PORT=5432

# Async DSN used by FastAPI / SQLAlchemy at runtime
DATABASE_URL=postgresql+asyncpg://logitrack:change_me_in_production@localhost:5432/logitrack

# Sync DSN used by Alembic migrations and ETL batch loads
DATABASE_SYNC_URL=postgresql+psycopg2://logitrack:change_me_in_production@localhost:5432/logitrack

# MLflow uses a separate logical database (auto-created by mlflow server)
MLFLOW_DB=mlflow

# -----------------------------------------------------------------------------
# Security / Auth
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_secret_key_generated_locally
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed CORS origins.
# Production: set to your actual frontend domain(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Redis — rate limiting + token blacklist cache
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

# Full Redis URL used by the backend (leave blank to use in-memory store for dev)
REDIS_URL=redis://:change_me_in_production@localhost:6379/0

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Used by the application to connect to MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_in_production
S3_BUCKET_NAME=logitrack

# -----------------------------------------------------------------------------
# MLflow experiment tracking
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5050
MLFLOW_PORT=5050

# -----------------------------------------------------------------------------
# Adminer (dev only)
# -----------------------------------------------------------------------------
ADMINER_PORT=8080

# -----------------------------------------------------------------------------
# ML / Prediction
# -----------------------------------------------------------------------------
ALERT_THRESHOLD=0.65

# -----------------------------------------------------------------------------
# ETL / Data paths
# -----------------------------------------------------------------------------
DATA_RAW_PATH=data/raw

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Options: development | staging | production
ENVIRONMENT=development
